# ==============================================================================
# MOYEOLOG Deployment Environment Configuration Template (.env.example)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Configuration (MySQL)
# ------------------------------------------------------------------------------
MYSQL_DATABASE=moyeolog
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_PASSWORD=your_db_password
MYSQL_USER=root

# ------------------------------------------------------------------------------
# 2. Backend Configuration (Spring Boot)
# ------------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/moyeolog?serverTimezone=Asia/Seoul&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_db_password

# JWT Token Secret and expiration details (Should be a long random secure string)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Google Gemini API Key for OCR & Summarization
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 3. Frontend Configuration (Next.js & Next-Auth)
# ------------------------------------------------------------------------------
# App URLs
NEXT_PUBLIC_API_URL=https://your-domain.com
NEXTAUTH_URL=https://your-domain.com
BACKEND_INTERNAL_URL=http://app:8080

# Next-Auth Secret (Should be a long random secure string)
NEXTAUTH_SECRET=your_nextauth_secret_key_here

# Kakao OAuth credentials
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# Kakao Map API Key
NEXT_PUBLIC_KAKAO_MAP_API_KEY=your_kakao_map_api_key
